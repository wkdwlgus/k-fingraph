# Neo4j Aura — 인스턴스 생성 시 다운로드한 자격증명 파일(Neo4j-XXX-Created-…​.txt)의
# 변수명·값을 그대로 복사하면 된다. Aura는 USERNAME / DATABASE를 인스턴스 ID로 발급하며
# 변경 불가 — "neo4j"가 username이 아닌 점에 주의.
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USERNAME=xxxxx
NEO4J_PASSWORD=
NEO4J_DATABASE=xxxxx

# DART OpenAPI
DART_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Logging
LOG_LEVEL=INFO
